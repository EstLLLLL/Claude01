{
  "brands": [
    { "name": "OpenAI", "query": "OpenAI", "match": "openai" },
    { "name": "Anthropic", "query": "Anthropic", "match": "anthropic" },
    { "name": "xAI (Grok)", "query": "xAI OR Grok", "match": "xai|grok" },
    { "name": "Google Gemini", "query": "Google Gemini", "match": "gemini" },
    { "name": "Meta AI", "query": "Meta AI OR Llama", "match": "meta ai|llama" },
    { "name": "Mistral AI", "query": "Mistral AI", "match": "mistral" },
    { "name": "DeepSeek", "query": "DeepSeek OR 深度求索", "match": "deepseek|深度求索" },
    { "name": "字节跳动 ByteDance", "query": "ByteDance OR 字节跳动 OR 豆包 OR Doubao", "match": "bytedance|字节跳动|豆包|doubao" },
    { "name": "MiniMax", "query": "MiniMax OR 海螺AI", "match": "minimax|海螺" },
    { "name": "智谱 Zhipu AI", "query": "Zhipu OR 智谱 OR 智谱清言 OR GLM", "match": "zhipu|智谱|glm" },
    { "name": "月之暗面 Moonshot (Kimi)", "query": "Kimi OR 月之暗面 OR Moonshot AI", "match": "moonshot|kimi|月之暗面" },
